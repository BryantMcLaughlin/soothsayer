<% content_for :title, "Rankings" %>

<!-- Centered Content -->
<div class="text-center">
  <!-- Logo Spot -->
  <div class="mb-4">
    <!-- Corrected path for logo -->
    <img src="<%= asset_path('/home/blmclaughlin/soothsayer/app/assets/images/Logo.jpeg') %>" alt="Logo" class="img-fluid" style="max-width: 200px;">
  </div>

  <!-- Heading -->
  <h1>Rankings</h1>

  <!-- Display Rankings -->
  <div id="rankings">
    <% @rankings.each do |ranking| %>
      <%= render ranking %>
      <p>
        <%= link_to "Show this ranking", ranking %>
      </p>
    <% end %>
  </div>

  <!-- Link to Create New Ranking -->
  <%= link_to "Create a new ranking", new_ranking_path, class: "btn btn-primary mt-4" %>
</div>
